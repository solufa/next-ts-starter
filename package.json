{
  "name": "next-ts-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "run-p dev:*",
    "dev:next": "next dev",
    "dev:hcm": "hcm 'src/**/*.module.css' -w",
    "hcm": "hcm 'src/**/*.module.css'",
    "build": "next build",
    "lint": "run-p lint:*",
    "lint:oxc": "oxlint && oxfmt --check",
    "lint:style": "stylelint \"src/**/*.css\" --ignore-path .gitignore",
    "fix:lint": "oxlint --fix && npm run lint:style -- --fix && oxfmt",
    "start": "next start",
    "typecheck": "npm run hcm && tsc --noEmit"
  },
  "dependencies": {
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "happy-css-modules": "^4.0.0",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "stylelint": "^17.9.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
